<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Defuddle Proxy</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { bg: '#09090b' }
        }
      }
    }
  </script>
</head>
<body class="bg-bg min-h-screen antialiased text-zinc-100">
  <%- include('layout-nav') %>

  <main class="max-w-4xl mx-auto px-6 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-lg font-semibold tracking-tight">Dashboard</h1>
        <p class="text-xs text-zinc-600 mt-0.5">管理 API 密钥与查看调用统计</p>
      </div>
      <div class="flex items-center gap-4 text-xs text-zinc-500">
        <span>成功率 <span class="<%= successRate >= 90 ? 'text-emerald-500' : successRate >= 70 ? 'text-yellow-500' : 'text-red-400' %> font-mono tabular-nums"><%= successRate %>%</span></span>
        <span>总调用 <span class="text-zinc-300 font-mono tabular-nums"><%= totalUsage %></span> 次</span>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 mb-6 border-b border-zinc-800">
      <a href="/admin/?tab=keys" class="px-4 py-2 text-sm transition-colors <%= tab === 'keys' ? 'text-zinc-100 border-b-2 border-zinc-100 -mb-px' : 'text-zinc-500 hover:text-zinc-300' %>">API Keys</a>
      <a href="/admin/?tab=domains" class="px-4 py-2 text-sm transition-colors <%= tab === 'domains' ? 'text-zinc-100 border-b-2 border-zinc-100 -mb-px' : 'text-zinc-500 hover:text-zinc-300' %>">域名排行</a>
    </div>

    <% if (tab === 'keys') { %>
    <!-- Keys tab -->
    <form method="POST" action="/admin/keys" class="flex gap-2 mb-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="text" name="name" placeholder="备注名称（如：小明）"
        class="flex-1 bg-zinc-900 border border-zinc-800 rounded-md px-3 py-2 text-sm text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-1 focus:ring-zinc-600 focus:border-zinc-600 transition-colors">
      <button type="submit"
        class="bg-zinc-800 text-zinc-200 border border-zinc-700 rounded-md px-4 py-2 text-sm font-medium hover:bg-zinc-700 transition-colors whitespace-nowrap shrink-0">
        创建 Key
      </button>
    </form>

    <div class="border border-zinc-800 rounded-lg overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-zinc-800 bg-zinc-900/50">
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">名称</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">API Key</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">创建时间</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">上次使用</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">调用</th>
            <th class="px-4 py-2.5 w-12"></th>
          </tr>
        </thead>
        <tbody>
          <% keys.forEach(function(k) { %>
          <tr class="border-b border-zinc-800/50 last:border-0 hover:bg-zinc-900/30 transition-colors cursor-pointer" onclick="window.location='/admin/keys/<%= k.id %>/stats'">
            <td class="px-4 py-3 text-sm">
              <span class="text-zinc-300">
                <% if (k.name) { %><%= k.name %><% } else { %><span class="text-zinc-600">未命名</span><% } %>
              </span>
            </td>
            <td class="px-4 py-3" onclick="event.stopPropagation()">
              <div class="flex items-center gap-1.5">
                <code class="text-xs text-zinc-400 font-mono"><%= k.key.slice(0, 7) %><span class="text-zinc-700">···</span><%= k.key.slice(-4) %></code>
                <button onclick='copyText(<%- JSON.stringify(k.key) %>, this)' class="text-zinc-700 hover:text-zinc-400 transition-colors p-0.5" title="复制">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                </button>
              </div>
            </td>
            <td class="px-4 py-3 text-xs text-zinc-500"><%= new Date(k.created_at).toLocaleDateString('zh-CN') %></td>
            <td class="px-4 py-3 text-xs text-zinc-500">
              <% if (k.last_used) { %><%= new Date(k.last_used).toLocaleString('zh-CN') %><% } else { %><span class="text-zinc-700">—</span><% } %>
            </td>
            <td class="px-4 py-3">
              <span class="text-xs font-mono text-zinc-400 tabular-nums"><%= k.usage_count %></span>
            </td>
            <td class="px-4 py-3 text-right" onclick="event.stopPropagation()">
              <div class="flex items-center justify-end gap-2">
                <button onclick='renameKey(<%= k.id %>, <%- JSON.stringify(k.name || '') %>)' class="text-zinc-700 hover:text-zinc-300 transition-colors" title="编辑">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                </button>
                <form method="POST" action="/admin/keys/<%= k.id %>/delete" class="inline" onsubmit="return confirm('确定删除？')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="text-zinc-700 hover:text-red-500 transition-colors" title="删除">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
          <% if (keys.length === 0) { %>
          <tr><td colspan="6" class="px-4 py-12 text-center text-xs text-zinc-600">暂无 Key</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <!-- Domains tab -->
    <div class="border border-zinc-800 rounded-lg overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-zinc-800 bg-zinc-900/50">
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500 w-6"></th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">域名</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">Key</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">调用</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">成功率</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-zinc-500">上次访问</th>
          </tr>
        </thead>
        <tbody>
          <% var offset = (domainPage - 1) * 10; %>
          <% domainStats.forEach(function(d, i) { %>
          <tr class="border-b border-zinc-800/50 last:border-0 hover:bg-zinc-900/30 transition-colors cursor-pointer" onclick="window.location='/admin/domains/<%= encodeURIComponent(d.domain) %>/stats'">
            <td class="px-4 py-2.5 text-xs text-zinc-600 tabular-nums"><%= offset + i + 1 %></td>
            <td class="px-4 py-2.5 text-sm font-mono text-zinc-300"><%= d.domain %></td>
            <td class="px-4 py-2.5 text-xs text-zinc-400"><%= d.key_names %></td>
            <td class="px-4 py-2.5 text-xs font-mono text-zinc-400 tabular-nums"><%= d.count %></td>
            <td class="px-4 py-2.5 text-xs font-mono tabular-nums">
              <span class="<%= d.success_rate >= 90 ? 'text-emerald-500' : d.success_rate >= 70 ? 'text-yellow-500' : 'text-red-400' %>"><%= d.success_rate %>%</span>
            </td>
            <td class="px-4 py-2.5 text-xs text-zinc-500"><%= new Date(d.last_accessed).toLocaleString('zh-CN') %></td>
          </tr>
          <% }); %>
          <% if (domainStats.length === 0) { %>
          <tr><td colspan="6" class="px-4 py-12 text-center text-xs text-zinc-600">暂无数据</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- Pagination -->
    <%
      var currentPage = tab === 'keys' ? keyPage : domainPage;
      var totalPages = tab === 'keys' ? keyPages : domainPages;
    %>
    <% if (totalPages > 1) { %>
    <div class="flex items-center justify-center gap-1 mt-4">
      <% for (var p = 1; p <= totalPages; p++) { %>
        <% if (p === currentPage) { %>
        <span class="px-3 py-1 text-xs font-mono text-zinc-100 bg-zinc-800 rounded"><%= p %></span>
        <% } else { %>
        <a href="/admin/?tab=<%= tab %>&<%= tab === 'keys' ? 'key' : 'domain' %>_page=<%= p %>" class="px-3 py-1 text-xs font-mono text-zinc-500 hover:text-zinc-300 hover:bg-zinc-900 rounded transition-colors"><%= p %></a>
        <% } %>
      <% } %>
    </div>
    <% } %>
  </main>

  <script>
    var CSRF_TOKEN = <%- JSON.stringify(csrfToken) %>;

    function renameKey(id, currentName) {
      var newName = prompt('修改备注名称：', currentName);
      if (newName === null) return;
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/admin/keys/' + id + '/rename';
      var csrfInput = document.createElement('input');
      csrfInput.type = 'hidden';
      csrfInput.name = '_csrf';
      csrfInput.value = CSRF_TOKEN;
      form.appendChild(csrfInput);
      var input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'name';
      input.value = newName;
      form.appendChild(input);
      document.body.appendChild(form);
      form.submit();
    }

    function copyText(text, btn) {
      var done = function() {
        btn.innerHTML = '<svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(function() {
          btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>';
        }, 2000);
      };
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(done);
      } else {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        done();
      }
    }
  </script>
</body>
</html>
