<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= domain %> - 域名详情</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { bg: '#09090b' }
        }
      }
    }
  </script>
</head>
<body class="bg-bg min-h-screen antialiased text-zinc-100">
  <%- include('layout-nav') %>

  <main class="max-w-4xl mx-auto px-6 py-8">
    <a href="/admin/?tab=domains" class="inline-flex items-center gap-1 text-xs text-zinc-600 hover:text-zinc-400 transition-colors mb-6">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      返回排行
    </a>

    <div class="mb-8">
      <h1 class="text-lg font-semibold tracking-tight font-mono"><%= domain %></h1>
      <p class="text-xs text-zinc-600 mt-1">总调用 <span class="text-zinc-300 font-mono tabular-nums"><%= totalCount %></span> 次</p>
    </div>

    <div class="border border-zinc-800 rounded-lg overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-zinc-800 bg-zinc-900/50">
            <th class="text-left px-4 py-2 text-xs font-medium text-zinc-500">时间</th>
            <th class="text-left px-4 py-2 text-xs font-medium text-zinc-500">URL</th>
            <th class="text-left px-4 py-2 text-xs font-medium text-zinc-500">Key</th>
            <th class="text-left px-4 py-2 text-xs font-medium text-zinc-500">状态</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach(function(l) { %>
          <tr class="border-b border-zinc-800/50 last:border-0">
            <td class="px-4 py-2.5 text-xs text-zinc-500 whitespace-nowrap"><%= new Date(l.created_at).toLocaleString('zh-CN') %></td>
            <td class="px-4 py-2.5 text-xs text-zinc-400 break-all"><%= l.url %></td>
            <td class="px-4 py-2.5 text-xs text-zinc-500 whitespace-nowrap"><%= l.key_name %></td>
            <td class="px-4 py-2.5">
              <span class="text-xs font-mono <%= l.status_code >= 400 ? 'text-red-400' : 'text-zinc-500' %>"><%= l.status_code %></span>
            </td>
          </tr>
          <% }); %>
          <% if (logs.length === 0) { %>
          <tr><td colspan="4" class="px-4 py-8 text-center text-xs text-zinc-600">暂无数据</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <% if (pages > 1) { %>
    <div class="flex items-center justify-center gap-1 mt-4">
      <% for (var p = 1; p <= pages; p++) { %>
        <% if (p === page) { %>
        <span class="px-3 py-1 text-xs font-mono text-zinc-100 bg-zinc-800 rounded"><%= p %></span>
        <% } else { %>
        <a href="/admin/domains/<%= encodeURIComponent(domain) %>/stats?page=<%= p %>" class="px-3 py-1 text-xs font-mono text-zinc-500 hover:text-zinc-300 hover:bg-zinc-900 rounded transition-colors"><%= p %></a>
        <% } %>
      <% } %>
    </div>
    <% } %>
  </main>
</body>
</html>
