<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Key 统计 - Defuddle Proxy</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { bg: '#09090b' }
        }
      }
    }
  </script>
</head>
<body class="bg-bg min-h-screen antialiased text-zinc-100">
  <%- include('layout-nav') %>

  <main class="max-w-4xl mx-auto px-6 py-8">
    <a href="/admin/?tab=keys" class="inline-flex items-center gap-1 text-xs text-zinc-600 hover:text-zinc-400 transition-colors mb-6">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      返回列表
    </a>

    <!-- Key info -->
    <div class="mb-6">
      <h1 class="text-lg font-semibold tracking-tight"><%= keyInfo.name || '未命名 Key' %></h1>
      <div class="flex items-center gap-2 mt-1">
        <code class="text-xs text-zinc-600 font-mono" id="keyDisplay"><%= keyInfo.maskedKey %></code>
        <button onclick="revealKey(this)" class="text-zinc-700 hover:text-zinc-400 transition-colors p-0.5" title="显示完整 Key">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
        </button>
        <button onclick="copyFullKey(this)" class="text-zinc-700 hover:text-zinc-400 transition-colors p-0.5" title="复制完整 Key">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </button>
      </div>
      <p class="text-xs text-zinc-600 mt-2">总调用 <span class="text-zinc-300 font-mono tabular-nums"><%= totalCount %></span> 次</p>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 mb-6 border-b border-zinc-800">
      <a href="/admin/keys/<%= keyInfo.id %>/stats?tab=logs" class="px-4 py-2 text-sm transition-colors <%= tab === 'logs' ? 'text-zinc-100 border-b-2 border-zinc-100 -mb-px' : 'text-zinc-500 hover:text-zinc-300' %>">最近请求</a>
      <a href="/admin/keys/<%= keyInfo.id %>/stats?tab=daily" class="px-4 py-2 text-sm transition-colors <%= tab === 'daily' ? 'text-zinc-100 border-b-2 border-zinc-100 -mb-px' : 'text-zinc-500 hover:text-zinc-300' %>">每日调用</a>
    </div>

    <% if (tab === 'logs') { %>
    <!-- Recent logs -->
    <div class="border border-zinc-800 rounded-lg overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-zinc-800 bg-zinc-900/50">
            <th class="text-left px-4 py-2 text-xs font-medium text-zinc-500">时间</th>
            <th class="text-left px-4 py-2 text-xs font-medium text-zinc-500">URL</th>
            <th class="text-left px-4 py-2 text-xs font-medium text-zinc-500">状态</th>
          </tr>
        </thead>
        <tbody>
          <% recentLogs.forEach(function(l) { %>
          <tr class="border-b border-zinc-800/50 last:border-0">
            <td class="px-4 py-2.5 text-xs text-zinc-500 whitespace-nowrap"><%= new Date(l.created_at).toLocaleString('zh-CN') %></td>
            <td class="px-4 py-2.5 text-xs text-zinc-400 break-all"><%= l.url %></td>
            <td class="px-4 py-2.5">
              <span class="text-xs font-mono <%= l.status_code >= 400 ? 'text-red-400' : 'text-zinc-500' %>"><%= l.status_code %></span>
            </td>
          </tr>
          <% }); %>
          <% if (recentLogs.length === 0) { %>
          <tr><td colspan="3" class="px-4 py-8 text-center text-xs text-zinc-600">暂无数据</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <!-- Daily stats -->
    <div class="border border-zinc-800 rounded-lg overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-zinc-800 bg-zinc-900/50">
            <th class="text-left px-4 py-2 text-xs font-medium text-zinc-500">日期</th>
            <th class="text-left px-4 py-2 text-xs font-medium text-zinc-500">次数</th>
          </tr>
        </thead>
        <tbody>
          <% dailyStats.forEach(function(s) { %>
          <tr class="border-b border-zinc-800/50 last:border-0">
            <td class="px-4 py-2.5 text-xs font-mono text-zinc-400 tabular-nums"><%= s.date %></td>
            <td class="px-4 py-2.5 text-xs font-mono text-zinc-300 tabular-nums"><%= s.count %></td>
          </tr>
          <% }); %>
          <% if (dailyStats.length === 0) { %>
          <tr><td colspan="2" class="px-4 py-8 text-center text-xs text-zinc-600">暂无数据</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- Pagination -->
    <%
      var currentPage = tab === 'logs' ? logsPage : dailyPage;
      var totalPages = tab === 'logs' ? logsPages : dailyPages;
      var pageParam = tab === 'logs' ? 'logs_page' : 'daily_page';
    %>
    <% if (totalPages > 1) { %>
    <div class="flex items-center justify-center gap-1 mt-4">
      <% for (var p = 1; p <= totalPages; p++) { %>
        <% if (p === currentPage) { %>
        <span class="px-3 py-1 text-xs font-mono text-zinc-100 bg-zinc-800 rounded"><%= p %></span>
        <% } else { %>
        <a href="/admin/keys/<%= keyInfo.id %>/stats?tab=<%= tab %>&<%= pageParam %>=<%= p %>" class="px-3 py-1 text-xs font-mono text-zinc-500 hover:text-zinc-300 hover:bg-zinc-900 rounded transition-colors"><%= p %></a>
        <% } %>
      <% } %>
    </div>
    <% } %>
  </main>

  <script>
    var FULL_KEY = <%- JSON.stringify(keyInfo.key) %>;
    var revealed = false;

    function revealKey(btn) {
      var el = document.getElementById('keyDisplay');
      if (!revealed) {
        el.textContent = FULL_KEY;
        revealed = true;
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.59 6.59m7.532 7.532l3.29 3.29M3 3l18 18"/></svg>';
        btn.title = '隐藏 Key';
      } else {
        el.textContent = '<%= keyInfo.maskedKey %>';
        revealed = false;
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>';
        btn.title = '显示完整 Key';
      }
    }

    function copyFullKey(btn) {
      var done = function() {
        btn.innerHTML = '<svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(function() {
          btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>';
        }, 2000);
      };
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(FULL_KEY).then(done);
      } else {
        var ta = document.createElement('textarea');
        ta.value = FULL_KEY;
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        done();
      }
    }
  </script>
</body>
</html>
