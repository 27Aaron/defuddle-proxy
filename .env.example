# 服务端口
PORT=3000

# 监听地址，本地开发用 127.0.0.1，Docker 部署用 0.0.0.0
HOST=127.0.0.1

# 设为 production 启用安全检查和 cookie secure
NODE_ENV=development

# 管理后台用户名
ADMIN_USERNAME=admin

# 管理后台密码（生产环境必须修改，否则拒绝启动）
ADMIN_PASSWORD=changeme

# Session 加密密钥（生产环境必须修改，否则拒绝启动）
SESSION_SECRET=changeme-to-a-random-long-string

# SQLite 数据库路径
DB_PATH=./data/defuddle.db

# 仅 HTTPS 时设为 true，让 cookie 只在 HTTPS 下传输
COOKIE_SECURE=false

# 时区
TZ=Asia/Shanghai
